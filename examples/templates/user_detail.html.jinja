{% extends "base.html.jinja" %}

{% block content %}
<div class="card">
    <h1>{{ detail_user.name }}</h1>

    <table>
        <tr>
            <th>ID</th>
            <td>{{ detail_user.id }}</td>
        </tr>
        <tr>
            <th>Name</th>
            <td>{{ detail_user.name }}</td>
        </tr>
        <tr>
            <th>Email</th>
            <td>{{ detail_user.email }}</td>
        </tr>
        <tr>
            <th>Role</th>
            <td>{{ detail_user.role }}</td>
        </tr>
    </table>

    <p style="margin-top: 20px;">
        <a href="/users" class="btn">Back to Users</a>
    </p>
</div>
{% endblock %}
